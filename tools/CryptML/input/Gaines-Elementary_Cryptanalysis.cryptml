      "id": "C-II-FIG-2",
      "raw": "INSPECT DETAILS FOR TRIGLETH ACKNOWLEDGE THE BONDS FROM FEWELL",
      "charset": "[\\s\\S]",
      "casesensitive": true,
      "cipher_system": "concealment",
      "solution": {
        "plaintext": "STRIKE NOW",
        "key": "Align on left, read down third column"
